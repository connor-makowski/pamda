
{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "plan",
    "allow": [
      "Read(./pamda/**)",
      "Edit(./pamda/**)",
      "Write(./pamda/**)",
      "Read(./test/**)",
      "Edit(./test/**)",
      "Write(./test/**)",
      "Read(./utils/**)",
      "Edit(./utils/**)",
      "Write(./utils/**)",
      "Read(./README.md)",
      "Edit(./README.md)",
      "Write(./README.md)",
      "Bash(./run.sh prettify)",
      "Bash(uv run *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(*.env*)",
      "Read(**/*.env*)",
      "Read(**/*key*/**)",
      "Read(**/secret/**)",
      "Bash(rm *)",
      "Bash(git *)",
      "Read(cache/**)",
      "Read(dist/**)",
      "Read(**/__pycache__/**)",
      "Read(**/venv/**)"
    ]
  }
}